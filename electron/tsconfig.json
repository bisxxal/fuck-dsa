{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": [
            "ES2022",
            "dom"
        ],
        "moduleResolution": "node",
        "outDir": "../dist-electron",
        "rootDir": ".",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true, 
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "jsx": "react-jsx",
        "allowSyntheticDefaultImports": true
    },
    "include": ["./**/*"],
    // "include": [
    //     "*.ts",
    //     "configHelper.ts",
    //     "../src/types/electron.d.ts"
    // ],
    "exclude": [
        "../node_modules"
    ]
}